QUESTDB_HOST=127.0.0.1
QUESTDB_PORT=8812
QUESTDB_WRITE_PORT=9009
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_DATABASE=qdb

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=trading

MARKET_DATA_DB_BACKEND=questdb

INDEX_SYNC_INTERVAL_SECONDS=86400
INDEX_COMPOSITION_PROVIDER=
# Optional local/demo provider. Use a production exchange/vendor provider for trading or risk.
# FIXED_INCOME_REFERENCE_PROVIDER=src.feeds.fixed_income_reference:provider
FIXED_INCOME_REFERENCE_PROVIDER=

IBKR_REST_APP_NAME=IBKRRestApp
IBKR_REST_CONNECT_ON_STARTUP=false
IBKR_REST_MARKET_DATA_TTL_SECONDS=5
IBKR_REST_MARKET_DATA_CACHE_MAXSIZE=512
IBKR_REST_OHLCV_RATE_LIMIT_RETRY_DELAY_SECONDS=60
IBKR_REST_OHLCV_RATE_LIMIT_RETRY_COUNT=1

# Telegram alerting (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_LOG_LEVEL=WARNING
