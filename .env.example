IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID=1
IBKR_API_CLIENT_ID=101
IBKR_SCHEDULER_CLIENT_ID=201
IBKR_DOCKER_HOST=host.docker.internal
IBKR_DOCKER_PORT=4001
IBKR_DOCKER_REST_BASE_URL=http://ibkr-rest-app:8000
IBKR_MARKET_DATA_LINES=100

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
